# Database Configuration
DATABASE_URL=sqlite:///./salesgpt.db

# Mock API Configuration
USE_MOCK_APIS=true
MOCK_API_URL=http://localhost:8001

# API URLs (automatically point to mock server when USE_MOCK_APIS=true)
APOLLO_API_URL=http://localhost:8001
SMARTLEAD_API_URL=http://localhost:8001
HUBSPOT_API_URL=http://localhost:8001

# API Keys (can be mock keys when using mock APIs)
APOLLO_API_KEY=mock_key
SMARTLEAD_API_KEY=mock_key
HUBSPOT_ACCESS_TOKEN=mock_token
OPENAI_API_KEY=your_openai_key_here

# Webhook Configuration
WEBHOOK_PORT=8000
WEBHOOK_SECRET_KEY=dev_secret_key_change_in_production

# LLM Configuration
GPT_MODEL=gpt-3.5-turbo-0613
SALESGPT_CONFIG_PATH=examples/example_agent_setup.json
SALESGPT_VERBOSE=false

# Smartlead Configuration
SMARTLEAD_FROM_EMAIL=test@example.com
SMARTLEAD_FROM_NAME=ASSCH Team
SMARTLEAD_REPLY_TO=test@example.com
SMARTLEAD_CAMPAIGN_NAME=ASSCH Outreach

# Default Campaign Settings
DEFAULT_GEOGRAPHY=New York, NY
DEFAULT_SPECIALTY=Dermatology
DEFAULT_BATCH_SIZE=50
QUEUE_REFILL_THRESHOLD=20

# Analytics Configuration
AB_TESTING_ENABLED=true
MIN_SAMPLE_SIZE_FOR_RECOMMENDATIONS=10
UCB_EXPLORATION_PARAMETER=2.0

# GEMflush Configuration (optional)
GEMFLUSH_USE_REAL_API=false
GEMFLUSH_API_KEY=
GEMFLUSH_API_URL=

# Cal.com Configuration (optional)
CAL_API_KEY=
CAL_BOOKING_LINK=

