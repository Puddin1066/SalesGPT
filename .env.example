# Apollo API Configuration
APOLLO_API_KEY=your_apollo_api_key_here
# Development: mock Apollo with local FastAPI (python mock_api_server.py, default :8001)
# USE_MOCK_APIS=true
# MOCK_API_URL=http://localhost:8001
# Optional override of mock root (must end up as .../v1 for the client)
# APOLLO_API_URL=http://localhost:8001/v1

# --- Outbound email (choose one) ---
# Option A — Zoho Mail (no Smartlead): set USE_ZOHO_STACK=true and Zoho OAuth below.
# Option B — Smartlead: USE_ZOHO_STACK=false and set SMARTLEAD_API_KEY.
USE_ZOHO_STACK=false

# Sender identity (any provider). Prefer neutral names; legacy Smartlead_* still work.
ZOHO_MAIL_FROM=hello@yourdomain.com
ZOHO_MAIL_FROM_NAME=Your Name
# ZOHO_MAIL_REPLY_TO=support@yourdomain.com
# OUTBOUND_CAMPAIGN_NAME=Outreach

# Smartlead only (omit if using Zoho only)
# SMARTLEAD_API_KEY=
# SMARTLEAD_API_URL=https://server.smartlead.ai/api/v1
# SMARTLEAD_CAMPAIGN_ID=12345

# Master switch for scripts/run_marketing_automation.py (daily-send / review-queue). webhook-info ignores this.
MARKETING_AUTOMATION_ENABLED=false

# --- Zoho CRM + Mail (when USE_ZOHO_STACK=true, HubSpot and Smartlead are not loaded) ---
# OAuth app must include scopes for Zoho CRM and Zoho Mail (e.g. ZohoCRM.modules.ALL, ZohoMail.messages.CREATE, ZohoMail.accounts.READ).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Must match API Console redirect URI exactly (used for one-time code exchange)
# ZOHO_OAUTH_REDIRECT_URI=https://127.0.0.1:8080/zoho/callback
# Optional comma-separated scopes for print_zoho_oauth_authorize_url.py
# ZOHO_OAUTH_SCOPES=ZohoMail.messages.CREATE,ZohoMail.accounts.READ,ZohoCRM.modules.ALL
# Data center: https://accounts.zoho.com | .eu | .in | .com.au | .jp | .ca
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_CRM_API_BASE=https://www.zohoapis.com/crm/v6
ZOHO_MAIL_API_BASE=https://mail.zoho.com
# From GET https://mail.zoho.com/api/accounts — required if you have multiple mail accounts
# ZOHO_MAIL_ACCOUNT_ID=
# Optional throttle between sends when using Zoho Mail compat (seconds)
# ZOHO_MAIL_SEND_DELAY_SECONDS=0
# Map pipeline stages to your Deals module picklist (or set on Contact via ZOHO_CONTACT_STAGE_FIELD)
# ZOHO_DEAL_STAGE_IDLE=Qualification
# ZOHO_DEAL_STAGE_ENGAGED=Qualification
# ZOHO_DEAL_STAGE_BOOKED=Closed Won
# ZOHO_DEAL_STAGE_CLOSED=Closed Lost
# ZOHO_CONTACT_STAGE_FIELD=Lead_Status
SMARTLEAD_INITIAL_SUBJECT=Quick question about your clinic's visibility
SMARTLEAD_INITIAL_BODY=Hi {{first_name}},\n\nI noticed {{clinic_name}} and wanted to share something that might interest you.\n\nWould you be open to a brief conversation?\n\nBest,\n{{from_name}}
SMARTLEAD_FOLLOWUP_SUBJECT=Following up on visibility
SMARTLEAD_FOLLOWUP_BODY=Hi {{first_name}},\n\nJust wanted to follow up on my previous message. I'd love to show you how we can improve {{clinic_name}}'s patient acquisition.\n\nBest,\n{{from_name}}

# SalesGPT Configuration
SALESGPT_CONFIG_PATH=examples/example_agent_setup.json
GPT_MODEL=gpt-3.5-turbo-0613
# false = no LangChain tools (no Chroma / OpenAIEmbeddings). Enough for email reply + orchestrator. Set true for product-catalog RAG (needs compatible openai<1.55 with langchain-openai 0.0.x).
SALESGPT_USE_TOOLS=false

# Cal.com Scheduler
CAL_BOOKING_LINK=https://cal.com/your-booking-link

# HubSpot CRM
HUBSPOT_API_KEY=your_hubspot_api_key_here

# GEMflush Visibility API
GEMFLUSH_API_KEY=your_gemflush_api_key_here
GEMFLUSH_API_URL=https://api.gemflush.com/v1
DEFAULT_COMPETITOR=local competitors

# Default Search Parameters
DEFAULT_GEOGRAPHY=New York, NY
DEFAULT_SPECIALTY=Dermatology

# Webhook Configuration
WEBHOOK_PORT=8001

# OpenAI (for SalesGPT)
OPENAI_API_KEY=your_openai_api_key_here
